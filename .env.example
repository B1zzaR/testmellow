# =============================================================================
# VPN Platform — Environment Variables Template
#
# Copy this file to .env and fill in all values before starting the stack.
# NEVER commit .env — it is listed in .gitignore.
#
# Generate strong secrets:
#   openssl rand -hex 32          → 64-char hex string  (DB/Redis passwords)
#   openssl rand -hex 64          → 128-char hex string (JWT secret)
# =============================================================================

# ─── Domain & Admin ───────────────────────────────────────────────────────────
DOMAIN=mellowpn.space
ADMIN_EMAIL=mellowpn.buisness@gmail.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vpn
# openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=vpnplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (the app panics at startup if shorter).
# openssl rand -hex 64
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_32_CHARS

# ─── Platega (payment provider) ───────────────────────────────────────────────
PLATEGA_MERCHANT_ID=your-platega-merchant-uuid
PLATEGA_SECRET=your-platega-api-secret
# !! IMPORTANT: path must be /webhooks/platega — NOT /api/webhooks/platega !!
# The Caddy router exposes /webhooks/* directly; the Go app registers the
# handler at /webhooks/platega (cfg.App.WebhookPath).  Adding /api/ prefix
# causes every incoming payment webhook to return 404.
PLATEGA_CALLBACK_URL=https://yourdomain.com/webhooks/platega

# ─── Remnawave (VPN backend) ──────────────────────────────────────────────────
REMNA_BASE_URL=https://admin.yourdomain.com
REMNA_API_KEY=your-remnawave-api-key
# Optional: assign new users to a specific squad (leave empty if unused)
REMNA_SQUAD_UUID=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=CHANGE_ME_BOT_TOKEN
# Numeric user ID of the primary admin  (use @userinfobot to find yours)
TELEGRAM_ADMIN_ID=0
# Username WITHOUT the @ sign  (e.g. myvpnbot)
TELEGRAM_BOT_USERNAME=your_bot_username
# Public URL of the web app shown inside Telegram  (usually == https://DOMAIN)
WEBAPP_URL=https://yourdomain.com

# ─── Application ──────────────────────────────────────────────────────────────
# Username that receives automatic admin privileges on first login / register.
ADMIN_LOGIN=admin
# Comma-separated allowed CORS origins.  NEVER use * in production.
ALLOWED_ORIGINS=https://yourdomain.com
