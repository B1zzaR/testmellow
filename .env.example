# =============================================================================
# VPN Platform — Environment Variables Template
#
# Copy this file to .env and fill in all values before starting the stack.
# NEVER commit .env — it is listed in .gitignore.
#
# Generate strong secrets:
#   openssl rand -hex 32          → 64-char hex string  (DB/Redis passwords)
#   openssl rand -hex 64          → 128-char hex string (JWT secret)
# =============================================================================

# ─── Domain & Admin ───────────────────────────────────────────────────────────
DOMAIN=mellowpn.space
ADMIN_EMAIL=mellowpn.buisness@gmail.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vpn
# openssl rand -hex 32
POSTGRES_PASSWORD=32448effb5bf38e1cbd351294a180ddbd9afb783b16cf0053047269eea085e4b
POSTGRES_DB=vpnplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
REDIS_PASSWORD=3a667b83e2a7e7c524e59818313b0bf05c824f590eb7e3260d0b5bfdf8752cb3

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (the app panics at startup if shorter).
# openssl rand -hex 64
JWT_SECRET=29eaa579e1c0c05da4bcbf67d5bca7ad76dd6bbdd8f77eb60d832914b34ddf38505624b2963f6ed2def185e8a92316c48065a7bed141eae3e0b37cb6c62940b8

# ─── Platega (payment provider) ───────────────────────────────────────────────
PLATEGA_MERCHANT_ID=e1f89aea-106f-44d0-9c5f-3164b3c70409
PLATEGA_SECRET=dSNqCTvSOgj8gurErGTmfNgQRHI9yJCVUsTKviaEQY33fsq8ST2Z4AyykVHPpbw5FlGCPjEnrwLDtDI3HCxK6sOzbwwklQDfRlVP
# !! IMPORTANT: path must be /webhooks/platega — NOT /api/webhooks/platega !!
# The Caddy router exposes /webhooks/* directly; the Go app registers the
# handler at /webhooks/platega (cfg.App.WebhookPath).  Adding /api/ prefix
# causes every incoming payment webhook to return 404.
PLATEGA_CALLBACK_URL=https://mellowpn.space/webhooks/platega

# ─── Remnawave (VPN backend) ──────────────────────────────────────────────────
# IMPORTANT: This must be the URL of your Remnawave panel, NOT your platform domain.
# Example: https://panel.yourdomain.com or http://remnawave-host:3000
# If this points to your own domain (mellowpn.space), all API calls will hit
# your Go backend which has no /api/users route and will return 404.
REMNA_BASE_URL=https://admin.mellowpn.space
REMNA_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1dWlkIjoiNDkxZGNiZDgtOTRkZC00OTk2LTgwNGEtYjAyMWZmMmJkMDdkIiwidXNlcm5hbWUiOm51bGwsInJvbGUiOiJBUEkiLCJpYXQiOjE3NzQzODI1NzksImV4cCI6MTA0MTQyOTYxNzl9.4xiXaMxZjvWdGPPD-Df2ZviyHL1hdDxIDS1qtiAzowU
# Optional: assign new users to a specific squad (leave empty if unused)
REMNA_SQUAD_UUID=400f1678-5187-4a82-9d7d-97d6f52b878b

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=8601607275:AAFD24xmuqWaISSTVop-5OQI7jeQgI3svPc
# Numeric user ID of the primary admin  (use @userinfobot to find yours)
TELEGRAM_ADMIN_ID=7171348315
# Username WITHOUT the @ sign  (e.g. myvpnbot)
TELEGRAM_BOT_USERNAME=mellowpn_bot
# Public URL of the web app shown inside Telegram  (usually == https://DOMAIN)
WEBAPP_URL=https://mellowpn.space

# ─── Application ──────────────────────────────────────────────────────────────
# Username that receives automatic admin privileges on first login / register.
ADMIN_LOGIN=admin
# Comma-separated allowed CORS origins.  NEVER use * in production.
ALLOWED_ORIGINS=https://mellowpn.space
