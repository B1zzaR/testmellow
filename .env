# 📍 DOMAIN SETTINGS
DOMAIN=mellowpn.space
ADMIN_EMAIL=mellowpn.buisness@gmail.com

# ─── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=vpn
POSTGRES_PASSWORD=REGENERATE_SEE_ENV_EXAMPLE
POSTGRES_DB=vpnplatform

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=REGENERATE_SEE_ENV_EXAMPLE

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=REGENERATE_SEE_ENV_EXAMPLE

# ─── Platega ───────────────────────────────────────────────────────────
PLATEGA_MERCHANT_ID=REGENERATE_SEE_ENV_EXAMPLE
PLATEGA_SECRET=REGENERATE_SEE_ENV_EXAMPLE
PLATEGA_CALLBACK_URL=https://mellowpn.space/webhooks/platega

# ─── Remnawave ─────────────────────────────────────────────────────────
REMNA_BASE_URL=https://admin.mellowpn.space
REMNA_API_KEY=REGENERATE_SEE_ENV_EXAMPLE
REMNA_SQUAD_UUID=

# ─── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_TOKEN=REGENERATE_SEE_ENV_EXAMPLE
TELEGRAM_ADMIN_ID=0

# ─── Admin ─────────────────────────────────────────────────────────────
ADMIN_LOGIN=admin

# 🤖 Bot username (without @)
TELEGRAM_BOT_USERNAME=your_bot_username

# 🌐 Telegram WebApp URL shown inside the bot
WEBAPP_URL=https://mellowpn.space

# 🔗 CORS — comma-separated, no trailing slash, no wildcard in production
ALLOWED_ORIGINS=https://mellowpn.space