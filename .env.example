# =============================================================================
# VPN Platform — Environment Variables Template
#
# Copy this file to .env and fill in all values before starting the stack.
# NEVER commit .env — it is listed in .gitignore.
#
# This template MUST contain only placeholders. Earlier revisions of this
# file accidentally committed live secrets; if you pulled the project before
# they were scrubbed, treat them as compromised and rotate everything.
#
# Generate strong secrets:
#   openssl rand -hex 32          → 64-char hex string  (DB/Redis passwords)
#   openssl rand -hex 64          → 128-char hex string (JWT secret)
# =============================================================================

# ─── Domain & Admin ───────────────────────────────────────────────────────────
DOMAIN=example.com
# Real address — Let's Encrypt sends expiry notifications here. Mistyped =
# silently expired certificates ~80 days from now.
ADMIN_EMAIL=admin@example.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vpn
# openssl rand -hex 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_64_HEX
POSTGRES_DB=vpnplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_64_HEX

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (the app panics at startup if shorter).
# openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_128_HEX

# ─── Platega (payment provider) ───────────────────────────────────────────────
PLATEGA_MERCHANT_ID=REPLACE_WITH_YOUR_MERCHANT_ID
PLATEGA_SECRET=REPLACE_WITH_YOUR_PLATEGA_SECRET
# Optional. Set during a secret rotation: put the previous secret here while
# the new one is in PLATEGA_SECRET. Both will be accepted by the webhook
# verifier for ~24–48 h, then this MUST be cleared so a leaked old value
# stops working. Leaving this populated long-term defeats the rotation.
PLATEGA_SECRET_PREV=
# !! IMPORTANT: path must be /webhooks/platega — NOT /api/webhooks/platega !!
# The Caddy router exposes /webhooks/* directly; the Go app registers the
# handler at /webhooks/platega (cfg.App.WebhookPath).  Adding /api/ prefix
# causes every incoming payment webhook to return 404.
PLATEGA_CALLBACK_URL=https://example.com/webhooks/platega

# ─── Remnawave (VPN backend) ──────────────────────────────────────────────────
# IMPORTANT: This must be the URL of your Remnawave panel, NOT your platform domain.
# Example: https://panel.yourdomain.com or http://remnawave-host:3000
# If this points to your own domain, all API calls will hit your Go backend
# which has no /api/users route and will return 404.
REMNA_BASE_URL=https://panel.example.com
REMNA_API_KEY=REPLACE_WITH_REMNAWAVE_API_KEY
# Optional: assign new users to a specific squad (leave empty if unused)
REMNA_SQUAD_UUID=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
# Username WITHOUT the @ sign  (e.g. myvpnbot)
TELEGRAM_BOT_USERNAME=your_bot_username
# Public URL of the web app shown inside Telegram  (usually == https://DOMAIN)
WEBAPP_URL=https://example.com

# ─── Application ──────────────────────────────────────────────────────────────
# One-shot token for creating the first admin. The user who registers with
# `bootstrap_token` matching this value AND while no admin exists yet will be
# made admin. After the first admin is created the token is a no-op; clear it
# from the env to remove the attack surface entirely.
#   openssl rand -hex 32
# Leave empty to disable; promote subsequent admins via:
#   UPDATE users SET is_admin = TRUE WHERE username = 'foo';
ADMIN_BOOTSTRAP_TOKEN=
# JWT access-token lifetime in hours. Range: 1..24, default 1.
JWT_ACCESS_TTL_HOURS=1
# Comma-separated allowed CORS origins. MUST be explicit in production —
# the server refuses to start with '*' when APP_ENV=production.
ALLOWED_ORIGINS=https://example.com
# Comma-separated host names accepted as `return_url` / `failed_url` when a
# user initiates a Platega payment. Any other value is silently rewritten to
# WEBAPP_URL — this prevents a phishing redirect after a legitimate payment.
# No scheme, no path; just hosts. Empty falls back to {DOMAIN, www.DOMAIN}.
ALLOWED_RETURN_HOSTS=example.com,www.example.com
